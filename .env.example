# Shared
NODE_ENV=development

# API
PORT=4000
APP_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_vsa

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_REALTIME_MODEL=gpt-realtime-mini
OPENAI_VOICE=alloy

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+10000000000
TWILIO_WHATSAPP_NUMBER=+14155238886
TWILIO_PUBLIC_WEBHOOK_URL=https://your-public-url.ngrok-free.app
TWILIO_MEDIA_STREAM_URL=wss://your-realtime-bridge.example/ws/twilio

# WhatsApp
WHATSAPP_PROVIDER=twilio
WHATSAPP_VERIFY_TOKEN=dev-verify-token
META_WHATSAPP_TOKEN=your_meta_whatsapp_token
META_WHATSAPP_PHONE_NUMBER_ID=your_meta_phone_number_id
CUSTOM_WHATSAPP_API_URL=https://your-custom-whatsapp-api.example/send
CUSTOM_WHATSAPP_API_KEY=your_custom_whatsapp_api_key

# CRM
CRM_PROVIDER=hubspot
HUBSPOT_ACCESS_TOKEN=your_hubspot_access_token
CUSTOM_CRM_WEBHOOK_URL=https://your-crm-webhook.example/leads

# Calendar
CALENDAR_PROVIDER=google
GOOGLE_CALENDAR_ID=your_google_calendar_id
GOOGLE_CALENDAR_ACCESS_TOKEN=your_google_calendar_access_token
CALENDLY_BOOKING_URL=https://calendly.com/your-team/discovery-call
CUSTOM_CALENDAR_WEBHOOK_URL=https://your-calendar-webhook.example/book

# Web
VITE_API_BASE_URL=http://localhost:4000
